# ─── AWS Power Keys (used server-side for STS AssumeRole — never exposed to users) ───
POWER_AWS_ACCESS_KEY_ID=
POWER_AWS_SECRET_ACCESS_KEY=
POWER_AWS_REGION=us-east-1
BASE_ROLE_ARN=                       # IAM role ARN the power keys can assume

# ─── Admin ────────────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=devops@plane.so           # Superadmin email — system management only

# ─── SMTP (for OTP and notification emails) ───────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ─── Postgres ─────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=awsdashboard
POSTGRES_USER=awsdashboard
POSTGRES_PASSWORD=changeme

# ─── Valkey ───────────────────────────────────────────────────────────────────────────
VALKEY_URL=redis://valkey:6379

# ─── App ──────────────────────────────────────────────────────────────────────────────
SECRET_KEY=juss-uy-meen-laud-stof-faiw-laux-am   # used for signing tokens
