# ─── Admin ────────────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@company.com           # Superadmin email — system management only

# ─── AWS Power Keys (used server-side for STS AssumeRole — never exposed to users) ───
POWER_AWS_ACCESS_KEY_ID=
POWER_AWS_SECRET_ACCESS_KEY=
POWER_AWS_REGION=us-east-1
BASE_ROLE_ARN=arn:aws:iam::123456789012:role/PowerUserRole

# Collector: limit to regions you use (reduces API calls, avoids opt-in region errors). Empty = all regions.
# COLLECTOR_REGIONS=us-east-1,us-east-2,us-west-2

# ─── SMTP (for OTP and notification emails) ───────────────────────────────────────────
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@company.com

# ─── Postgres ─────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=awsdashboard
POSTGRES_USER=awsdashboard
POSTGRES_PASSWORD=                                # Required — no default, set a strong password

# ─── Valkey ───────────────────────────────────────────────────────────────────────────
VALKEY_PASSWORD=                                  # Required — no default, set a strong password
VALKEY_URL=redis://:${VALKEY_PASSWORD}@valkey:6379   # Also used as Celery broker if CELERY_BROKER_URL unset

# ─── App ──────────────────────────────────────────────────────────────────────────────
# REFRESH_STREAM_TIMEOUT_SECONDS=300   # SSE refresh-done timeout (default 300)
# SES_SUPPRESSION_SEARCH_LIMIT=20      # Max suppression search results (default 20)
# SES_BULK_REMOVE_MAX=20               # Max addresses per bulk-remove request (default 20)
# SES_MIN_SEARCH_CHARS=3               # Min query length for suppression search (default 3)
COOKIE_SECURE=false                               # Set to true in production (requires HTTPS)
CORS_ORIGINS=http://localhost:3000                # Comma-separated list of allowed origins
OTP_EXPIRY_MINUTES=10                             # How long an OTP code is valid
OTP_MAX_ATTEMPTS=5                                # Failed attempts before OTP is invalidated

# Auto-registration whitelist (optional — leave blank to disable)
# ALLOWED_DOMAINS=plane.so,contractor.com
